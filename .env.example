# --- Backend Configuration ---
# Internal port (Always 5000 inside Docker, can be 5001 for Local)
PORT=5001
NODE_ENV=development

# Database Configuration
# Use 'db' for Docker Local, 'mysql' for Docker Prod, or IP/localhost for Host Local
DB_HOST=localhost
DB_PORT=3306
DB_USER=user
DB_PASS=password
DB_NAME=fincthub_test
DB_DIALECT=mysql

# Security
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- Frontend Configuration ---
# Use http://localhost:5001 for Local, http://localhost:5001 for Docker Local
# (Docker Local uses mapping 5001:5000)
VITE_API_BASE_URL=http://localhost:5001
